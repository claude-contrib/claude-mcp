{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mcp.schema.json",
  "title": "Claude Services MCP Server Configuration",
  "type": "object",
  "minProperties": 1,
  "maxProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["command", "args"],
    "additionalProperties": false,
    "properties": {
      "command": {
        "type": "string",
        "minLength": 1
      },
      "args": {
        "type": "array",
        "items": { "type": "string" }
      },
      "env": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    }
  }
}
